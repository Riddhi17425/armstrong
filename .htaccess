<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On
 RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+index\.php[^\s]* [NC]
    RewriteRule ^index\.php/?(.*)$ /$1 [R=301,NC,L]
    # ----------------------------------------
    # 1️⃣ Custom redirect (your specific blog redirect)
    # Must be before Laravel rules
    # ----------------------------------------     
    RewriteCond %{HTTP_HOST} ^(www\.)?armstrongex\.com$ [NC]
    RewriteRule ^blog?$ https://www.armstrongex.com/blogs [R=301,L]
    RewriteRule ^blogs/how-mulch-film-punching-machines-improve/?$ https://www.armstrongex.com/blogs/mulch-film-punching-machines-for-better-yield-efficiency [R=301,L]
    RewriteRule ^blogs/improving-cleanroom-packaging-compliance/?$ https://www.armstrongex.com/blogs/cleanroom-packaging-with-advanced-inner-liner-machines [R=301,L]
    RewriteRule ^blogs/double-sided-printing-for-pp-bags/?$ https://www.armstrongex.com/blogs/double-sided-printing-for-pp-bags-with-printek-6 [R=301,L]
    RewriteRule ^blogs/why-liner-testing-is-crucial-for-packaging-quality-assurance/?$ https://www.armstrongex.com/blogs/liner-testing-is-crucial-for-packaging-quality [R=301,L]
    RewriteRule ^blogs/sewing-machines-can-reduce-labor-costs-and-increase-output/?$ https://www.armstrongex.com/blogs/sewing-machines-reduce-labor-costs-increase-output [R=301,L]
    RewriteRule ^blogs/small-bags-vs-large-bags-how-a-bale-press-machine-handles-both/?$ https://www.armstrongex.com/blogs/bale-press-machine-for-small-bags-large-bags [R=301,L]
    RewriteRule ^blogs/from-large-rolls-to-precise-cuts/?$ https://www.armstrongex.com/blogs/benefits-of-roll-conversion-in-large-rolls-precise-cuts [R=301,L]
    RewriteRule ^blogs/efficiency-and-profitability-with-flexographic-bag/?$ https://www.armstrongex.com/blogs/efficient-profitable-flexographic-bag-printing-technology [R=301,L]
    RewriteRule ^blogs/top-5-industries-benefiting-from-heavy-duty-webbing-loom-machines/?$ https://www.armstrongex.com/blogs/industries-benefits-from-heavy-duty-webbing-loom-machines [R=301,L]
    RewriteRule ^blogs/reducing-costs-with-mechanical-perforation-in-flexible-packaging-manufacturing/?$ https://www.armstrongex.com/blogs/cut-costs-with-mechanical-perforation-in-packaging [R=301,L]
    RewriteRule ^blogs/how-pinch-bottom-machines-are-revolutionizing-bag-packaging/?$ https://www.armstrongex.com/blogs/revolution-in-bag-packaging-using-pinch-bottom-machines [R=301,L]
    RewriteRule ^blogs/why-automatic-belt-stitching-machines-are-essential/?$ https://www.armstrongex.com/blogs/automatic-belt-stitching-machines-for-super-sack-bags [R=301,L]
    RewriteRule ^blogs/high-speed-roll-to-roll-gusseting-efficiency-in-manufacturing?$ https://www.armstrongex.com/blogs/high-speed-roll-to-roll-gusseting [R=301,L]
    RewriteRule ^blogs/streamlining-fibc-production-the-benefits-of-the-fabric-reversing-machine?$ https://www.armstrongex.com/blogs/streamlining-fibc-production-using-fabric-reversing-machine [R=301,L]
    RewriteRule ^blogs/liner-testing-machines-ensure-product-safety-during-transportation?$ https://www.armstrongex.com/blogs/liner-testing-machines-for-safe-product-transport [R=301,L]
    RewriteRule ^woven-bag-lamination-machine?$ https://www.armstrongex.com/product/woven-bag-lamination-machine [R=301,L]
    RewriteRule ^product/fabric-cutting-machine?$ https://www.armstrongex.com/product/fibc-fabric-cutting-machine [R=301,L]
    RewriteRule ^product/eight-color-flexographic-roll-to-roll-printing-machine?$ https://www.armstrongex.com/product/six-colors-roll-to-roll-flexographic-printing-machine [R=301,L]
    RewriteRule ^product/six-colours-roll-to-roll-flexographic-printing-machine-without-cylinder?$ https://www.armstrongex.com/product/six-colors-roll-to-roll-flexographic-printing-machine [R=301,L]
    RewriteRule ^products/fibc-fabric-cutting-machine?$ https://www.armstrongex.com/product/fibc-fabric-cutting-machine [R=301,L]
    RewriteRule ^category/sewing?$ https://www.armstrongex.com/category/sewing-machines [R=301,L]
     RewriteRule ^privacypolicy?$ https://www.armstrongex.com/privacy-policy [R=301,L]
     RewriteRule ^product/bcs-machine/?$ https://www.armstrongex.com/product/woven-fabric-cutting-stitching-machine [R=301,L]
     RewriteRule ^category/bag-closing/?$ https://www.armstrongex.com/category/bag-closing-machine [R=301,L]
     RewriteRule ^category/niddle-loom/?$ https://www.armstrongex.com/category/needle-loom [R=301,L]

    # ----------------------------------------
    # 2️⃣ Handle Authorization Header
    # ----------------------------------------
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # ----------------------------------------
    # 3️⃣ Handle X-XSRF-Token Header
    # ----------------------------------------
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # ----------------------------------------
    # 4️⃣ Redirect Trailing Slashes If Not A Folder
    # ----------------------------------------
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # ----------------------------------------
    # 5️⃣ Laravel front controller
    # ----------------------------------------
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]

    # ----------------------------------------
    # 6️⃣ Force HTTPS + www
    # ----------------------------------------
    RewriteCond %{HTTPS} !=on [OR]
    RewriteCond %{HTTP_HOST} !^www\. [NC]
    RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301,NE]

    # ----------------------------------------
    # 7️⃣ Security header
    # ----------------------------------------
    Header always set Content-Security-Policy "upgrade-insecure-requests;"
</IfModule>

# BEGIN cPanel-generated php ini directives, do not edit
# Manual editing of this file may result in unexpected behavior.
# To make changes to this file, use the cPanel MultiPHP INI Editor (Home >> Software >> MultiPHP INI Editor)
# For more information, read our documentation (https://go.cpanel.net/EA4ModifyINI)
<IfModule php8_module>
   php_flag display_errors On
   php_value max_execution_time 30
   php_value max_input_time 60
   php_value max_input_vars 1000
   php_value memory_limit 512M
   php_value post_max_size 256M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php82"
   php_value upload_max_filesize 256M
   php_flag zlib.output_compression Off
</IfModule>
<IfModule lsapi_module>
   php_flag display_errors On
   php_value max_execution_time 30
   php_value max_input_time 60
   php_value max_input_vars 1000
   php_value memory_limit 512M
   php_value post_max_size 256M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php82"
   php_value upload_max_filesize 256M
   php_flag zlib.output_compression Off
</IfModule>
# END cPanel-generated php ini directives, do not edit

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php82” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
